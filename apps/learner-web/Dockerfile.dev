FROM node:20-bookworm-slim

WORKDIR /app

COPY package.json package-lock.json tsconfig.base.json ./
COPY apps/learner-web/package.json apps/learner-web/package.json
COPY packages/activity-core/package.json packages/activity-core/package.json
COPY packages/activity-schema/package.json packages/activity-schema/package.json
COPY packages/asset-catalog/package.json packages/asset-catalog/package.json
COPY packages/learning-ui/package.json packages/learning-ui/package.json
COPY packages/shared-types/package.json packages/shared-types/package.json
COPY packages/theme/package.json packages/theme/package.json

RUN npm install

COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--workspace", "@koda/learner-web", "--", "--host", "0.0.0.0"]
